# ── Build stage ──────────────────────────────────────
FROM public.ecr.aws/docker/library/debian:trixie-slim AS base

ARG CCODOLO_AGENT

ENV DEBIAN_FRONTEND=noninteractive

RUN apt update && apt upgrade -y \
  && apt install -y --no-install-recommends \
    adduser \
    ca-certificates \
    curl \
    fzf \
    git \
    jq \
    less \
    locales \
    procps \
    sudo \
    unzip \
    vim \
    zsh \
  && apt-get clean && rm -rf /var/lib/apt/lists/* \
  && sed -i -e 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen \
  && echo 'LANG="en_US.UTF-8"' > /etc/default/locale \
  && dpkg-reconfigure locales \
  && update-locale LANG=en_US.UTF-8 \
  && adduser coder --shell /bin/zsh --disabled-password \
  && mkdir -p /workspace /home/coder/.local/bin /commandhistory \
  && touch /commandhistory/.bash_history /commandhistory/.zsh_history \
  && chown -R coder:coder /workspace /home/coder /commandhistory

USER coder
WORKDIR /workspace

COPY dotfiles/.bashrc dotfiles/.zshrc dotfiles/.inputrc /home/coder/

# Default powerline10k theme
ARG ZSH_IN_DOCKER_VERSION=1.2.1
RUN sh -c "$(curl -fsSL https://github.com/deluan/zsh-in-docker/releases/download/v${ZSH_IN_DOCKER_VERSION}/zsh-in-docker.sh)" -- \
    -p git -p fzf -x

# ── Bundled dev tools ────────────────────────────────
USER root
{{ range .ToolInstructions }}
{{ . }}
{{ end }}

# ── Custom build steps ───────────────────────────────
{{ range .CustomSteps }}
{{ . }}
{{ end }}

# ── npm config & agent installation ─────────────────
USER coder
{{ if .NpmConfig }}
{{ .NpmConfig }}
{{ end }}
{{ .AgentInstall }}

# ── Squash into single layer ─────────────────────────
FROM scratch
COPY --from=base / /

ENV SHELL=/bin/zsh
ENV EDITOR=vim
ENV VISUAL=vim
ENV HISTFILE=/commandhistory/.zsh_history
ENV HISTSIZE=100000
ENV SAVEHIST=100000
{{ range .ToolEnvVars }}
ENV {{ . }}
{{ end }}
ENV PATH="{{ .ToolPath }}"
{{ range .AgentExtraEnv }}
ENV {{ . }}
{{ end }}

USER coder
WORKDIR /workspace
ENTRYPOINT {{ .Entrypoint }}
